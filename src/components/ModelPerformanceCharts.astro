---
interface Props {
  benchmarks: any;
}

const { benchmarks } = Astro.props;
const { products, models, notes } = benchmarks;
---

<div id="perf-viz">
  <!-- Controls -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-6">
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold text-nvidia-gray-400 uppercase tracking-wider">Platform</span>
      <div class="inline-flex rounded-lg bg-nvidia-gray-100 p-0.5 flex-wrap gap-0.5" id="platform-btns">
        {products.filter((_: any, i: number) => i < 4).map((p: any, i: number) => (
          <button
            data-product={p.id}
            class:list={[
              'plat-btn px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-150',
              i === 0
                ? 'bg-nvidia-green text-nvidia-black shadow-sm'
                : 'text-nvidia-gray-600 hover:bg-nvidia-gray-200'
            ]}
          >
            {p.name}
          </button>
        ))}
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold text-nvidia-gray-400 uppercase tracking-wider">Concurrency</span>
      <div class="inline-flex rounded-lg bg-nvidia-gray-100 p-0.5">
        <button id="btn-c1" class="conc-btn px-3 py-1.5 text-xs font-semibold rounded-md bg-nvidia-green text-nvidia-black shadow-sm transition-all duration-150">C=1</button>
        <button id="btn-c8" class="conc-btn px-3 py-1.5 text-xs font-semibold rounded-md text-nvidia-gray-600 hover:bg-nvidia-gray-200 transition-all duration-150">C=8</button>
      </div>
    </div>
  </div>

  <!-- Chart -->
  <div id="dot-chart-wrap" class="relative rounded-xl border border-nvidia-gray-100 overflow-x-auto bg-white">
    <div id="dot-chart" class="min-w-[700px]"></div>
    <div id="chart-tooltip" class="hidden absolute pointer-events-none bg-nvidia-black text-white text-xs px-3 py-2 rounded-lg shadow-lg whitespace-nowrap z-10" style="transform: translate(12px, -50%)"></div>
  </div>

  <!-- Empty -->
  <div id="chart-empty" class="hidden text-center py-16 text-nvidia-gray-400">No data for this platform</div>

  <!-- Notes -->
  <div class="mt-5 space-y-0.5">
    <p class="text-[11px] text-nvidia-gray-600">* ISL/OSL for all benchmarks: 2048/128</p>
    {notes.map((n: string) => <p class="text-[11px] text-nvidia-gray-600">* {n}</p>)}
  </div>
</div>

<script is:inline define:vars={{ benchmarksData: benchmarks }}>
  window.__benchmarks = benchmarksData;
</script>

<script>
  const data: any = (window as any).__benchmarks;

  const familyColors: Record<string, string> = {
    'Nemotron':         '#76B900',
    'Cosmos Reasoning': '#00ACC1',
    'Qwen':             '#1976D2',
    'Gemma':            '#8E24AA',
    'GPT OSS':          '#F57C00',
    'DeepSeek':         '#E53935',
    'Pi':               '#00897B',
    'GR00T':            '#558B2F',
  };
  const fallbackColor = '#78909C';

  let product = data.products[0].id;
  let concurrency: 'concurrency1' | 'concurrency8' = 'concurrency1';

  const chartEl = document.getElementById('dot-chart')!;
  const wrap = document.getElementById('dot-chart-wrap')!;
  const tooltip = document.getElementById('chart-tooltip')!;
  const emptyEl = document.getElementById('chart-empty')!;

  const platBtns = document.querySelectorAll<HTMLButtonElement>('.plat-btn');

  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

  function parseDate(s: string): number { return new Date(s + 'T00:00:00').getTime(); }

  function formatDate(ts: number): string {
    const d = new Date(ts);
    return `${months[d.getMonth()]}. ${d.getFullYear()}`;
  }

  function niceMax(max: number): number {
    if (max <= 0) return 100;
    const p = max * 1.12;
    const exp = Math.floor(Math.log10(p));
    const mag = Math.pow(10, exp);
    const n = p / mag;
    let nice: number;
    if (n <= 1.5) nice = 1.5;
    else if (n <= 2) nice = 2;
    else if (n <= 2.5) nice = 2.5;
    else if (n <= 3) nice = 3;
    else if (n <= 4) nice = 4;
    else if (n <= 5) nice = 5;
    else if (n <= 7.5) nice = 7.5;
    else nice = 10;
    return nice * mag;
  }

  function render() {
    updateButtons();

    const items = data.models
      .map((m: any) => ({
        model: m,
        value: m.performance[concurrency][product] as number | null,
        date: parseDate(m.releaseDate),
      }))
      .filter((i: any) => i.value !== null && i.value !== undefined);

    if (items.length === 0) {
      chartEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      legendEl.innerHTML = '';
      return;
    }
    emptyEl.classList.add('hidden');

    // Axes ranges
    const allDates = items.map((i: any) => i.date as number);
    const minDate = Math.min(...allDates);
    const maxDate = Math.max(...allDates);
    const dateSpan = maxDate - minDate || 1;
    const datePadLeft = dateSpan * 0.06;
    const datePadRight = dateSpan * 0.18;
    const xMin = minDate - datePadLeft;
    const xMax = maxDate + datePadRight;

    const maxV = Math.max(...items.map((i: any) => i.value as number));
    const yMax = niceMax(maxV);

    // Layout
    const ml = 62, mr = 40, mt = 20, mb = 50;
    const w = 960;
    const chartH = 420;
    const h = mt + chartH + mb;
    const cw = w - ml - mr;

    const xScale = (ts: number) => ml + ((ts - xMin) / (xMax - xMin)) * cw;
    const yScale = (v: number) => mt + chartH - (v / yMax) * chartH;

    let s = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:auto;font-family:system-ui,-apple-system,sans-serif">`;

    // Y grid + ticks
    const yTicks = 5;
    const yStep = yMax / yTicks;
    for (let i = 0; i <= yTicks; i++) {
      const v = Math.round(yStep * i);
      const cy = yScale(v);
      s += `<line x1="${ml}" y1="${cy}" x2="${ml + cw}" y2="${cy}" stroke="${i === 0 ? '#E5E7EB' : '#F0F0F0'}"/>`;
      s += `<text x="${ml - 8}" y="${cy}" text-anchor="end" dominant-baseline="middle" fill="#9CA3AF" font-size="11">${v}</text>`;
    }

    // Y-axis title
    s += `<text x="14" y="${mt + chartH / 2}" text-anchor="middle" dominant-baseline="middle" fill="#9CA3AF" font-size="11" transform="rotate(-90,14,${mt + chartH / 2})">Tokens per Second</text>`;

    // X-axis date ticks — one per month boundary within range
    const startMonth = new Date(xMin);
    startMonth.setDate(1);
    let cursor = new Date(startMonth.getFullYear(), startMonth.getMonth(), 1);
    while (cursor.getTime() <= xMax + 30 * 86400000) {
      const ts = cursor.getTime();
      if (ts >= xMin && ts <= xMax) {
        const cx = xScale(ts);
        s += `<line x1="${cx}" y1="${mt}" x2="${cx}" y2="${mt + chartH}" stroke="#F5F5F5"/>`;
        s += `<line x1="${cx}" y1="${mt + chartH}" x2="${cx}" y2="${mt + chartH + 6}" stroke="#D1D5DB"/>`;
        s += `<text x="${cx}" y="${mt + chartH + 20}" text-anchor="middle" fill="#9CA3AF" font-size="10.5">${months[cursor.getMonth()]}. ${cursor.getFullYear()}</text>`;
      }
      cursor = new Date(cursor.getFullYear(), cursor.getMonth() + 1, 1);
    }

    // Axis lines
    s += `<line x1="${ml}" y1="${mt + chartH}" x2="${ml + cw}" y2="${mt + chartH}" stroke="#E5E7EB"/>`;
    s += `<line x1="${ml}" y1="${mt}" x2="${ml}" y2="${mt + chartH}" stroke="#E5E7EB"/>`;

    // X-axis title
    s += `<text x="${ml + cw / 2}" y="${h - 6}" text-anchor="middle" fill="#9CA3AF" font-size="11">Release Date</text>`;

    // Dots + labels
    // Sort so higher-value dots render on top
    const sorted = [...items].sort((a: any, b: any) => a.value - b.value);

    // Compute positions, then nudge overlapping dots apart
    const points = sorted.map((item: any) => ({
      item,
      x: xScale(item.date),
      y: yScale(item.value),
    }));

    const minDist = 14;
    for (let i = 0; i < points.length; i++) {
      for (let j = i + 1; j < points.length; j++) {
        const dx = points[j].x - points[i].x;
        const dy = points[j].y - points[i].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < minDist) {
          const push = (minDist - dist) / 2 + 0.5;
          points[i].x -= push;
          points[j].x += push;
          if (Math.abs(dy) < 4) {
            points[i].y -= push * 0.6;
            points[j].y += push * 0.6;
          }
        }
      }
    }

    points.forEach(({ item, x: cx, y: cy }: any) => {
      const c = familyColors[item.model.family] || fallbackColor;
      const unit = item.model.isl !== null ? 'tok/s' : 'inf/s';

      s += `<circle cx="${cx}" cy="${cy + 1}" r="6" fill="black" opacity="0.06"/>`;
      s += `<circle cx="${cx}" cy="${cy}" r="5.5" fill="${c}" stroke="white" stroke-width="1.5" opacity="0.92" class="perf-dot" data-tip="${item.model.name}  ·  ${item.value} ${unit}  ·  ${item.model.family}" style="cursor:pointer"/>`;
      s += `<text x="${cx + 9}" y="${cy - 9}" fill="#4B5563" font-size="10" pointer-events="none" class="perf-label" transform="rotate(-20,${cx + 9},${cy - 9})">${item.model.name}</text>`;
    });

    s += '</svg>';
    chartEl.innerHTML = s;

    attachHover();
  }

  function attachHover() {
    const dots = chartEl.querySelectorAll<SVGCircleElement>('.perf-dot');
    const labels = chartEl.querySelectorAll<SVGTextElement>('.perf-label');

    dots.forEach((dot, idx) => {
      dot.addEventListener('mouseenter', (e) => {
        dot.setAttribute('r', '8');
        dot.setAttribute('opacity', '1');
        dots.forEach((d, di) => { if (di !== idx) { d.setAttribute('opacity', '0.2'); } });
        labels.forEach((l, li) => { (l as SVGTextElement).setAttribute('opacity', li === idx ? '1' : '0.15'); });
        if (labels[idx]) {
          labels[idx].setAttribute('font-weight', '700');
          labels[idx].setAttribute('fill', '#111827');
          labels[idx].setAttribute('font-size', '11.5');
        }
        tooltip.textContent = dot.dataset.tip || '';
        tooltip.classList.remove('hidden');
        const r = wrap.getBoundingClientRect();
        tooltip.style.left = (e.clientX - r.left + 14) + 'px';
        tooltip.style.top = (e.clientY - r.top) + 'px';
      });

      dot.addEventListener('mousemove', (e) => {
        const r = wrap.getBoundingClientRect();
        tooltip.style.left = (e.clientX - r.left + 14) + 'px';
        tooltip.style.top = (e.clientY - r.top) + 'px';
      });

      dot.addEventListener('mouseleave', () => {
        dot.setAttribute('r', '5.5');
        dots.forEach(d => d.setAttribute('opacity', '0.92'));
        labels.forEach(l => {
          l.setAttribute('opacity', '1');
          l.setAttribute('font-weight', 'normal');
          l.setAttribute('fill', '#4B5563');
          l.setAttribute('font-size', '10');
        });
        tooltip.classList.add('hidden');
      });
    });
  }

  function updateButtons() {
    platBtns.forEach(b => {
      const on = b.dataset.product === product;
      b.className = `plat-btn px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-150 ${on ? 'bg-nvidia-green text-nvidia-black shadow-sm' : 'text-nvidia-gray-600 hover:bg-nvidia-gray-200'}`;
    });
    const isC1 = concurrency === 'concurrency1';
    (document.getElementById('btn-c1') as HTMLButtonElement).className =
      `conc-btn px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-150 ${isC1 ? 'bg-nvidia-green text-nvidia-black shadow-sm' : 'text-nvidia-gray-600 hover:bg-nvidia-gray-200'}`;
    (document.getElementById('btn-c8') as HTMLButtonElement).className =
      `conc-btn px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-150 ${!isC1 ? 'bg-nvidia-green text-nvidia-black shadow-sm' : 'text-nvidia-gray-600 hover:bg-nvidia-gray-200'}`;
  }

  platBtns.forEach(b => b.addEventListener('click', () => { product = b.dataset.product!; render(); }));
  document.getElementById('btn-c1')!.addEventListener('click', () => { concurrency = 'concurrency1'; render(); });
  document.getElementById('btn-c8')!.addEventListener('click', () => { concurrency = 'concurrency8'; render(); });

  render();
</script>
